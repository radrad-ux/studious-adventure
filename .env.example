# --- Google Sheets ---
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Orders
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# --- Anti-fraud ---
# Long random string, used to sign anti-bot tokens. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHALLENGE_SECRET=

# Minimum seconds a human needs to fill the form (bots submit instantly)
MIN_FILL_SECONDS=4
# Max age (seconds) of a page-load token before it's considered stale
MAX_TOKEN_AGE_SECONDS=1800
# Window (hours) to flag a repeated order from the same phone+product as a possible duplicate
DEDUPE_WINDOW_HOURS=24

PORT=3000
